// NOTE: This is a base TypeScript configuration.
// Paths defined here are relative to this file's location (config/typescript/).
// The primary, project-level path definitions are in the root tsconfig.json, which extends this file.
{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    },
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "outDir": "./dist",
    "sourceMap": true
  },
  "references": [
    {
      "path": "./app.json"
    },
    {
      "path": "./node.json"
    }
  ],
  "include": [
    "src",
    "shared",
    "tests",
    "test",
    "__tests__"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
